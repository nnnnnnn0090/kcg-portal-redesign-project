# このファイルをコピーして `app/.env.local` を作成し、値を入れてからビルドしてください。
# `.env.local` は .gitignore 済みです。

# Discord 招待 URL（例: https://discord.gg/xxxx）
VITE_PORTAL_DISCORD_INVITE_URL=

# バグ報告・機能リクエスト用フォーム URL
VITE_EXTENSION_FEEDBACK_FORM_URL=

# マスコットイラスト制作者の表示名とプロフィール URL
VITE_MASCOT_ILLUSTRATOR_NAME=
VITE_MASCOT_ILLUSTRATOR_URL=

# テレメトリ署名・マイリンク同期 JSON 暗号化（Web の TELEMETRY_HMAC_SECRET と同一。配布 zip ビルド時のみ bundle へ注入）
VITE_TELEMETRY_HMAC_SECRET=
