{
  "name": "kcg-portal-redesign-project",
  "version": "7.1.0",
  "private": true,
  "scripts": {
    "dev": "wxt",
    "dev:firefox": "wxt -b firefox",
    "build": "wxt build",
    "build:firefox": "wxt build -b firefox",
    "zip": "VITE_PORTAL_DISTRIBUTION_BUILD=1 wxt zip",
    "zip:firefox": "VITE_PORTAL_DISTRIBUTION_BUILD=1 wxt zip -b firefox",
    "zip:dev": "wxt zip",
    "zip:dev:firefox": "wxt zip -b firefox",
    "zip:all": "npm run zip:dev && npm run zip:dev:firefox && npm run zip && npm run zip:firefox",
    "postinstall": "wxt prepare",
    "lint": "eslint .",
    "type-coverage": "type-coverage --at-least 99.3 --strict",
    "test:coverage": "vitest run --coverage",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css}\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test --project=e2e",
    "test:e2e:flows": "playwright test --project=flows"
  },
  "dependencies": {
    "dompurify": "^3.4.11",
    "lucide-react": "^1.23.0",
    "marked": "^18.0.5",
    "motion-icons-react": "^1.1.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@playwright/test": "^1.51.1",
    "@types/chrome": "^0.0.316",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@types/webextension-polyfill": "^0.12.3",
    "@vitest/coverage-v8": "^3.0.5",
    "@wxt-dev/module-react": "^1.1.0",
    "autoprefixer": "^10.5.2",
    "dependency-cruiser": "^16.10.4",
    "eslint": "^9.17.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "jsdom": "^26.1.0",
    "postcss": "^8.5.16",
    "postcss-import": "^15.1.0",
    "prettier": "^3.4.2",
    "tailwindcss": "^3.4.17",
    "type-coverage": "^2.29.7",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.63.0",
    "vitest": "^3.0.5",
    "wxt": "^0.20.6"
  }
}
