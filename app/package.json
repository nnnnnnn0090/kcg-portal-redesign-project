{
  "name": "kcg-portal-redesign-project",
  "version": "6.0.0",
  "private": true,
  "scripts": {
    "dev": "wxt",
    "dev:firefox": "wxt -b firefox",
    "build": "wxt build",
    "build:firefox": "wxt build -b firefox",
    "zip": "wxt zip",
    "zip:firefox": "wxt zip -b firefox",
    "postinstall": "wxt prepare",
    "lint": "eslint .",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css}\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "chrome": "bash ../scripts/chrome-dev.sh",
    "chrome:stop": "bash ../scripts/chrome-dev.sh stop",
    "chrome:status": "bash ../scripts/chrome-dev.sh status",
    "chrome:verify": "bash ../scripts/chrome-dev.sh verify",
    "fixloop": "bash ../scripts/chrome-dev.sh",
    "fixloop:e2e": "bash ../scripts/chrome-dev.sh && EXTENSION_PATH=.output/chrome-mv3 npm run test:e2e"
  },
  "dependencies": {
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@playwright/test": "^1.59.1",
    "@types/chrome": "^0.0.316",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@types/webextension-polyfill": "^0.12.3",
    "@wxt-dev/module-react": "^1.1.0",
    "eslint": "^9.17.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "prettier": "^3.4.2",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.24.0",
    "vitest": "^3.0.5",
    "wxt": "^0.20.6"
  }
}
